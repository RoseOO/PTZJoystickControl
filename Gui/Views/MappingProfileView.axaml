<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="32"
             x:Class="PtzJoystickControl.Gui.Views.MappingProfileView">

	<StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
		<TextBlock Text="Profile:" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
		<ComboBox Items="{Binding ProfileNames}" SelectedItem="{Binding SelectedProfile}"
		          Width="120" Height="26" FontSize="10"/>
		<Button Content="Load" Command="{Binding LoadProfile}" Height="24" FontSize="10" Padding="6,1" VerticalAlignment="Center"/>
		<Button Content="Del" Command="{Binding DeleteProfile}" Height="24" FontSize="10" Padding="6,1" VerticalAlignment="Center"/>
		<TextBox Text="{Binding NewProfileName}" Watermark="Name..." Width="90" Height="24" FontSize="10" VerticalAlignment="Center"/>
		<Button Content="Save" Command="{Binding SaveProfile}" Height="24" FontSize="10" Padding="6,1" VerticalAlignment="Center"/>
	</StackPanel>
</UserControl>
