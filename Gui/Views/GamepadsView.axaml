<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PtzJoystickControl.Gui.ViewModels"
             xmlns:v="using:PtzJoystickControl.Gui.Views"
             mc:Ignorable="d" d:DesignWidth="550" d:DesignHeight="450"
             x:Class="PtzJoystickControl.Gui.Views.GamepadsView">
	<Grid RowDefinitions="Auto,Auto,Auto,*" ColumnDefinitions="*,Auto">
		<ComboBox Grid.Row="0" Items="{Binding AvailableGamepads}" SelectedItem="{Binding SelectedGamepadInfo}" Margin="10,10,10,0" HorizontalAlignment="Stretch">
			<ComboBox.Styles>
				<Style Selector="ComboBoxItem">
					<Setter
						Property="IsEnabled"
						Value="{Binding IsConnected}" />
				</Style>
			</ComboBox.Styles>
			<ComboBox.ItemTemplate>
				<DataTemplate>
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="{Binding Name}"/>
						<TextBlock Text=" (Disconnected)" IsVisible="{Binding !IsConnected}"/>
						<!--<ToggleSwitch IsEnabled="True" IsChecked="{Binding IsActivated}" OnContent="" OffContent=""></ToggleSwitch>-->
					</StackPanel>
				</DataTemplate>
			</ComboBox.ItemTemplate>
		</ComboBox>
		<ToggleSwitch Name="showAxisSettings" Grid.Row="0" Grid.Column="1" Margin="10,5,10,-5" VerticalAlignment="Center" OnContent="Advanced" OffContent="Advanced"/>

		<!-- Gamepad Settings: Zoom-Proportional Speed -->
		<StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8" Margin="10,6,10,0">
			<CheckBox IsChecked="{Binding ZoomProportionalMode}" VerticalAlignment="Center"
					  ToolTip.Tip="When enabled, pan/tilt speed is automatically reduced when zoomed in">
				<TextBlock Text="Zoom-proportional speed" FontSize="11"/>
			</CheckBox>
			<TextBlock Text="Factor" VerticalAlignment="Center" FontSize="11" Margin="8,0,0,0"/>
			<Slider Minimum="0" Maximum="0.95" Width="100"
					Value="{Binding ZoomProportionalFactor}"
					IsEnabled="{Binding ZoomProportionalMode}"
					ToolTip.Tip="How much to reduce pan/tilt speed at max zoom (0=none, 0.95=95% reduction)"/>
			<TextBlock Text="{Binding ZoomProportionalFactor, StringFormat={}{0:P0}}" VerticalAlignment="Center"
					   FontSize="10" Foreground="#999999"/>
		</StackPanel>

		<v:MappingProfileView Grid.Row="2" Grid.ColumnSpan="2" Margin="10,4,10,0" DataContext="{Binding MappingProfileViewModel}"/>

		<ScrollViewer Grid.Row="3" Grid.ColumnSpan="2" VerticalScrollBarVisibility="Visible" Margin="10">
			<ItemsControl Items="{Binding InputViewModels}">
				<ItemsControl.ItemTemplate>
					<DataTemplate DataType="{x:Type vm:InputViewModel}">
						<StackPanel Orientation="Vertical">
							<v:InputView />
							<Panel IsVisible="{Binding IsAxis}">
								<v:AxisSettingsView DataContext="{Binding}" IsVisible="{Binding #showAxisSettings.IsChecked}" Margin="2"/>
							</Panel>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</UserControl>
