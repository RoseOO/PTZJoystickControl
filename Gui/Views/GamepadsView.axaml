<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PtzJoystickControl.Gui.ViewModels"
             xmlns:v="using:PtzJoystickControl.Gui.Views"
             mc:Ignorable="d" d:DesignWidth="550" d:DesignHeight="450"
             x:Class="PtzJoystickControl.Gui.Views.GamepadsView">
	<Grid RowDefinitions="Auto,Auto,Auto,*" ColumnDefinitions="*,Auto">
		<ComboBox Grid.Row="0" Items="{Binding AvailableGamepads}" SelectedItem="{Binding SelectedGamepadInfo}" Margin="10,10,10,0" HorizontalAlignment="Stretch">
			<ComboBox.Styles>
				<Style Selector="ComboBoxItem">
					<Setter
						Property="IsEnabled"
						Value="{Binding IsConnected}" />
				</Style>
			</ComboBox.Styles>
			<ComboBox.ItemTemplate>
				<DataTemplate>
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="{Binding Name}"/>
						<TextBlock Text=" (Disconnected)" IsVisible="{Binding !IsConnected}"/>
						<TextBlock Text=" ●" Foreground="#4caf50" IsVisible="{Binding IsActivated}" Margin="4,0,0,0"
								   ToolTip.Tip="Active"/>
					</StackPanel>
				</DataTemplate>
			</ComboBox.ItemTemplate>
		</ComboBox>
		<StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="4" Margin="0,5,10,-5" VerticalAlignment="Center">
			<ToggleSwitch IsChecked="{Binding IsSelectedDeviceActive}" OnContent="Active" OffContent="Inactive"
						  ToolTip.Tip="Activate/deactivate this input device. Multiple devices can be active simultaneously."/>
			<ToggleSwitch Name="showAxisSettings" OnContent="Advanced" OffContent="Advanced"/>
		</StackPanel>

		<!-- Gamepad Settings: Zoom-Proportional Speed & Camera Assignment -->
		<StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="4" Margin="10,6,10,0">
			<StackPanel Orientation="Horizontal" Spacing="8">
				<TextBlock Text="Target Camera" VerticalAlignment="Center" FontSize="11" FontWeight="SemiBold"/>
				<ComboBox Items="{Binding AvailableCameras}" SelectedItem="{Binding DeviceSelectedCamera}"
						  Width="180" Height="28" FontSize="11"
						  ToolTip.Tip="Camera this device controls. Select a specific camera or leave empty to follow the main camera selection.">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding Name}"/>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>
			</StackPanel>
			<StackPanel Orientation="Horizontal" Spacing="8">
				<CheckBox IsChecked="{Binding ZoomProportionalMode}" VerticalAlignment="Center"
						  ToolTip.Tip="When enabled, pan/tilt speed is automatically reduced when zoomed in">
					<TextBlock Text="Zoom-proportional speed" FontSize="11"/>
				</CheckBox>
				<TextBlock Text="Factor" VerticalAlignment="Center" FontSize="11" Margin="8,0,0,0"/>
				<Slider Minimum="0" Maximum="0.95" Width="100"
						Value="{Binding ZoomProportionalFactor}"
						IsEnabled="{Binding ZoomProportionalMode}"
						ToolTip.Tip="How much to reduce pan/tilt speed at max zoom (0=none, 0.95=95% reduction)"/>
				<TextBlock Text="{Binding ZoomProportionalFactor, StringFormat={}{0:P0}}" VerticalAlignment="Center"
						   FontSize="10" Foreground="#999999"/>
			</StackPanel>
		</StackPanel>

		<v:MappingProfileView Grid.Row="2" Grid.ColumnSpan="2" Margin="10,4,10,0" DataContext="{Binding MappingProfileViewModel}"/>

		<ScrollViewer Grid.Row="3" Grid.ColumnSpan="2" VerticalScrollBarVisibility="Visible" Margin="10">
			<ItemsControl Items="{Binding InputViewModels}">
				<ItemsControl.ItemTemplate>
					<DataTemplate DataType="{x:Type vm:InputViewModel}">
						<StackPanel Orientation="Vertical">
							<v:InputView />
							<Panel IsVisible="{Binding IsAxis}">
								<v:AxisSettingsView DataContext="{Binding}" IsVisible="{Binding #showAxisSettings.IsChecked}" Margin="2"/>
							</Panel>
						</StackPanel>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</UserControl>
